# ──────────────────────────────────────────────
# Finance Support Triage Agent — Environment Variables
# Copy this to .env and fill in your values
# On Streamlit Cloud, add these in App Settings → Secrets
# ──────────────────────────────────────────────

# ── Database (PostgreSQL — Railway / Neon / Supabase / Aiven) ──
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Groq API Key (https://console.groq.com/keys) ──
GROQ_API_KEY=gsk_your_key_here

# ── Gmail Credentials (for IMAP fetch + SMTP send) ──
# Use a Gmail App Password, NOT your regular password
# Generate at: Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=yourname@gmail.com
EMAIL_PASSWORD=abcd efgh ijkl mnop
EMAIL_POLL_INTERVAL=300

# ── Frontend API URL (set automatically on Railway, override for local dev) ──
# API_BASE_URL=http://127.0.0.1:8000
